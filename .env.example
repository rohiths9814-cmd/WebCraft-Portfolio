# ==============================
# WebCraft Portfolio — Contact
# Copy this file to .env and fill in your real details
# ==============================

# Your WhatsApp number (with country code, no spaces or dashes)
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX

# Your phone number (display format)
VITE_PHONE_DISPLAY=+91 XXXXX XXXXX

# Your email
VITE_EMAIL=your@email.com

# Your location
VITE_LOCATION=Your City, India

# Working hours
VITE_HOURS=Mon – Sat, 9AM – 9PM

# Default WhatsApp message
VITE_WA_DEFAULT_MSG=Hi, I saw your portfolio. I want a website for my shop.

# Social links
VITE_SOCIAL_GITHUB=https://github.com/yourusername
VITE_SOCIAL_LINKEDIN=https://linkedin.com/in/yourusername
VITE_SOCIAL_TWITTER=https://twitter.com/yourusername
VITE_SOCIAL_INSTAGRAM=https://instagram.com/yourusername
